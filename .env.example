# ─── Neo4j ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel_swarm_2024

# ─── Kafka ───
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=banking.events
KAFKA_TOPIC_ALERTS=sentinel.alerts
KAFKA_CONSUMER_GROUP=sentinel-swarm

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── LLM Providers ───
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
LLAMA_BASE_URL=http://localhost:8080/v1
LLAMA_MODEL=llama-3-70b

# ─── OSINT APIs ───
ABUSEIPDB_API_KEY=your-abuseipdb-key
MAXMIND_LICENSE_KEY=your-maxmind-key
HIBP_API_KEY=your-hibp-key

# ─── Prometeo Open Banking ───
PROMETEO_API_KEY=your-prometeo-api-key
PROMETEO_SANDBOX=true

# ─── Thresholds ───
THRESHOLD_SENTINEL=0.30
THRESHOLD_BLOCK=0.85
THRESHOLD_ESCALATE=0.65
THRESHOLD_MONITOR=0.40
MAX_LATENCY_TOTAL_MS=15000
MONITORING_HOURS=72

# ─── Agent Weights ───
WEIGHT_SENTINEL=0.25
WEIGHT_OSINT=0.20
WEIGHT_PATTERNS=0.20
WEIGHT_HISTORIAN=0.15
WEIGHT_JURIST=0.20

# ─── Operational ───
ROS_AUTO_SUBMIT=true
PARALLEL_AGENTS=true
LOG_LEVEL=INFO
ENVIRONMENT=development
